{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Vala Help Center",
  "colors": {
    "primary": "#6D5DFB",
    "light": "#8B7CFF",
    "dark": "#4C3BD9"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "getting-started/welcome",
              "getting-started/quickstart"
            ]
          },
          {
            "group": "Core workflows",
            "pages": [
              "workflows/veterans",
              "features/chat-with-vala",
              "workflows/reports",
              "workflows/forms-and-vsign"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Vala",
          "href": "https://valaclaims.com",
          "icon": "house"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Vala website",
        "href": "https://valaclaims.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Vala",
      "href": "https://app.valaclaims.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
